# Example environment variables for the backend (ApiProyecto)
# Copy values into your environment or use User Secrets for local development.

# Connection string name used by configuration
ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=ProyectoPersonalDb;Trusted_Connection=True;

# JWT settings
Jwt__Key=SuperSecretKey123456789012345678901234567890
Jwt__Issuer=ProyectoPersonal
Jwt__Audience=ProyectoPersonalUsers
Jwt__ExpiryInMinutes=60
Jwt__RefreshTokenExpiryInDays=30

# Frontend dev URL for CORS
Frontend__DevUrl=http://localhost:3000
